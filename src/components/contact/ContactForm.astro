<section class="mx-auto w-[90%] max-w-6xl pb-24 mb-20 z-10 relative">
  <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
    <div class="rounded-[32px] border border-white/10 bg-zinc-950/80 p-8 md:p-10">
      <h2 class="text-2xl font-semibold text-white md:text-3xl">
        Envie uma mensagem
      </h2>

      <p class="mt-3 max-w-2xl text-zinc-400">
        Preencha o formulário e retornaremos o mais breve possível.
      </p>

      <form class="mt-8 flex flex-col gap-5">
        <div class="grid gap-5 md:grid-cols-2">
          <div>
            <label for="name" class="mb-2 block text-sm text-zinc-300">
              Nome
            </label>
            <input
              id="name"
              name="name"
              type="text"
              placeholder="Seu nome"
              class="w-full rounded-2xl border border-white/10 bg-zinc-900 px-4 py-3 text-white outline-none transition focus:border-cyan-400/40"
            />
          </div>

          <div>
            <label for="email" class="mb-2 block text-sm text-zinc-300">
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              placeholder="seuemail@exemplo.com"
              class="w-full rounded-2xl border border-white/10 bg-zinc-900 px-4 py-3 text-white outline-none transition focus:border-cyan-400/40"
            />
          </div>
        </div>

        <div>
          <label for="subject" class="mb-2 block text-sm text-zinc-300">
            Assunto
          </label>
          <input
            id="subject"
            name="subject"
            type="text"
            placeholder="Sobre o que você quer falar?"
            class="w-full rounded-2xl border border-white/10 bg-zinc-900 px-4 py-3 text-white outline-none transition focus:border-cyan-400/40"
          />
        </div>

        <div>
          <label for="message" class="mb-2 block text-sm text-zinc-300">
            Mensagem
          </label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder="Digite sua mensagem..."
            class="w-full rounded-2xl border border-white/10 bg-zinc-900 px-4 py-3 text-white outline-none transition focus:border-cyan-400/40"
          ></textarea>
        </div>

        <button
          type="submit"
          class="w-fit rounded-full bg-cyan-400 px-6 py-3 font-medium text-black transition hover:scale-[1.02]"
        >
          Enviar mensagem
        </button>
      </form>
    </div>

    <aside class="rounded-[32px] border border-white/10 bg-zinc-950/80 p-8 md:p-10">
      <h2 class="text-2xl font-semibold text-white">Informações</h2>

      <div class="mt-6 space-y-6">
        <div>
          <p class="text-sm uppercase tracking-wide text-zinc-500">Atendimento</p>
          <p class="mt-2 text-zinc-300">
            Segunda a sexta, das 9h às 18h
          </p>
        </div>

        <div>
          <p class="text-sm uppercase tracking-wide text-zinc-500">Email</p>
          <p class="mt-2 text-zinc-300">Indisponível no momento</p>
        </div>

        <div>
          <p class="text-sm uppercase tracking-wide text-zinc-500">WhatsApp</p>
          <p class="mt-2 text-zinc-300">Indisponível no momento</p>
        </div>
      </div>
    </aside>
  </div>
</section>