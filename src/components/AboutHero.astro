---
/* src/components/AboutHero.astro */
---

<section class="relative overflow-hidden border-b border-white/10 bg-[radial-gradient(circle_at_50%_35%,#070427_0%,#090538_50%,#000_100%)]">
  
  <div class="mt-15 mx-auto flex min-h-[60vh] w-[90%] max-w-6xl items-center py-24 z-10 relative reveal">
    
    <div class="max-w-3xl">
      <span class="mb-4 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-1 text-sm text-cyan-300">
        Sobre a equipe
      </span>

      <h1 class="text-4xl font-bold leading-tight text-white md:text-6xl">
        Criamos páginas e experiências digitais com visual moderno e foco em resultado
      </h1>

      <p class="mt-6 text-lg leading-8 text-zinc-300">
        Somos uma equipe focada em construir projetos digitais com identidade forte,
        estética tecnológica e atenção à experiência do usuário.
      </p>
    </div>
  </div>
  <div id="stars" class="stars"></div>
</section>

<script>
      const starsContainer = document.getElementById("stars");

      if (starsContainer) {
        const totalStars = 220;

        for (let i = 0; i < totalStars; i++) {
          const star = document.createElement("div");

          const size = Math.random() * 3 + 1;

          star.style.position = "absolute";
          star.style.width = `${size}px`;
          star.style.height = `${size}px`;
          star.style.background = "white";
          star.style.borderRadius = "50%";

          star.style.top = Math.random() * 100 + "%";
          star.style.left = Math.random() * 100 + "%";

          star.style.opacity = `${Math.random()}`;

          star.style.animation = `starFloat ${Math.random() * 50 + 50}s linear infinite`;

          starsContainer.appendChild(star);
        }
      }
    </script>