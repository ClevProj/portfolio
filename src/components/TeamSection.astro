---
import { teamMembers } from "../data/team";
---

<section class="mx-auto w-[90%] max-w-6xl py-20 z-10 relative reveal " id="equipe">
  <div class="mb-10">
    <span class="mb-4 inline-block rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-1 text-sm text-cyan-300">
      Equipe
    </span>

    <h2 class="text-3xl font-bold text-white md:text-5xl">
      Quem está por trás dos projetos
    </h2>
  </div>

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 z-10 relative">
    {teamMembers.map((member) => (
      <article class="rounded-[28px] border border-white/10 bg-zinc-950/80 p-6 transition duration-300 hover:-translate-y-1 hover:border-cyan-400/30">
        <img
          src={member.image}
          alt={`Foto de ${member.name}`}
          class="mb-5 h-20 w-20 rounded-full object-cover ring-2 ring-white/10"
        />

        <h3 class="text-xl font-semibold text-white">{member.name}</h3>
        <p class="mt-1 text-sm text-cyan-300">{member.role}</p>

        <p class="mt-4 text-sm leading-6 text-zinc-400">
          {member.description}
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <a
            href={member.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-zinc-200 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-300"
          >
            LinkedIn
          </a>

          <a
            href={member.github}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-zinc-200 transition hover:border-cyan-400/30 hover:bg-cyan-400/10 hover:text-cyan-300"
          >
            GitHub
          </a>
        </div>
      </article>
    ))}
  </div>
</section>