---
/* src/components/CtaSection.astro */
---

<section class="mx-auto w-[90%] max-w-6xl py-20 z-10 relative reveal">
  <div class="rounded-[32px] border border-cyan-400/20 bg-[radial-gradient(circle_at_center,rgba(34,211,238,0.12),rgba(9,9,11,0.95)_60%)] p-10 text-center">
    <h2 class="text-3xl font-bold text-white md:text-5xl">
      Vamos criar algo forte para a sua presença digital
    </h2>

    <p class="mx-auto mt-4 max-w-2xl text-zinc-300">
      Se você quer uma página com visual moderno, estrutura profissional e foco em apresentação,
      entre em contato com a nossa equipe.
    </p>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/contato"
        class="rounded-full bg-cyan-400 px-6 py-3 font-medium text-black transition hover:scale-[1.02]"
      >
        Entrar em contato
      </a>

      <a
        href="/#projects-wrapper"
        class="rounded-full border border-white/10 bg-white/5 px-6 py-3 font-medium text-white transition hover:bg-white/10"
      >
        Ver portfólio
      </a>
    </div>
  </div>
</section>